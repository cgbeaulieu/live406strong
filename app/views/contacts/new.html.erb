<section class="border-b border-brand-teal/10 bg-gradient-to-br from-brand-teal via-brand-teal-dark to-brand-teal-darkest py-10 text-white md:py-12">
  <div class="mx-auto max-w-6xl px-4">
    <h1 class="heading-display font-serif text-4xl font-bold text-white md:text-5xl">Get in touch</h1>
    <p class="mt-2 text-lg text-white/85">Tell us your goals—we will follow up to schedule your free consultation or answer your question.</p>
  </div>
</section>

<div class="mx-auto max-w-6xl px-4 py-12 md:py-16">
  <div class="grid gap-10 lg:grid-cols-12 lg:gap-12">
    <div class="lg:col-span-7">
      <%= form_for @contact, url: contact_path, html: { class: "rounded-2xl border border-brand-teal/10 bg-white p-6 shadow-lg ring-1 ring-black/5 md:p-8", data: { turbo: false }, novalidate: true } do |f| %>
        <% if @contact.errors.any? %>
          <div class="mb-5 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-950" role="alert" aria-live="polite">
            <p class="font-semibold">Please fix the following before sending:</p>
            <ul class="mt-1 list-inside list-disc">
              <% @contact.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="space-y-5">
          <% input_base = "w-full rounded-xl border px-4 py-3 text-base text-brand-text shadow-sm outline-none ring-brand-sky/40 transition focus:border-brand-sky focus:ring-2 focus:ring-brand-sky/40" %>
          <% border_for = ->(field) { @contact.errors[field].any? ? "border-red-400" : "border-slate-300" } %>

          <div>
            <%= f.label :name, class: "mb-1 block text-sm font-semibold text-brand-teal" %>
            <%= f.text_field :name,
                  class: "#{input_base} #{border_for.call(:name)}",
                  placeholder: "Your name",
                  required: true,
                  autocomplete: "name",
                  aria: { invalid: @contact.errors[:name].any?, describedby: ('contact_name_error' if @contact.errors[:name].any?) } %>
            <% if @contact.errors[:name].any? %>
              <p id="contact_name_error" class="mt-1 text-sm text-red-700"><%= @contact.errors[:name].to_sentence %></p>
            <% end %>
          </div>

          <div>
            <%= f.label :email, class: "mb-1 block text-sm font-semibold text-brand-teal" %>
            <%= f.email_field :email,
                  class: "#{input_base} #{border_for.call(:email)}",
                  placeholder: "you@example.com",
                  required: true,
                  autocomplete: "email",
                  aria: { invalid: @contact.errors[:email].any?, describedby: ('contact_email_error' if @contact.errors[:email].any?) } %>
            <% if @contact.errors[:email].any? %>
              <p id="contact_email_error" class="mt-1 text-sm text-red-700"><%= @contact.errors[:email].to_sentence %></p>
            <% end %>
          </div>

          <div>
            <%= f.label :message, class: "mb-1 block text-sm font-semibold text-brand-teal" %>
            <%= f.text_area :message,
                  class: "min-h-[140px] #{input_base} #{border_for.call(:message)}",
                  rows: 6,
                  placeholder: "Share what you are working toward, preferred days or times, and whether you prefer in-studio or virtual.",
                  required: true,
                  aria: { invalid: @contact.errors[:message].any?, describedby: ('contact_message_error' if @contact.errors[:message].any?) } %>
            <% if @contact.errors[:message].any? %>
              <p id="contact_message_error" class="mt-1 text-sm text-red-700"><%= @contact.errors[:message].to_sentence %></p>
            <% end %>
          </div>

          <div class="hidden" aria-hidden="true">
            <%= f.text_field :nickname, autocomplete: "off", tabindex: -1 %>
          </div>

          <div>
            <%= f.submit "Send message", class: "btn-brand w-full cursor-pointer sm:w-auto" %>
          </div>
        </div>
      <% end %>
    </div>
    <div class="lg:col-span-5">
      <div class="rounded-2xl border border-brand-teal/10 bg-white p-6 shadow-lg ring-1 ring-black/5 md:p-8">
        <h2 class="heading-display font-serif text-xl font-semibold text-brand-teal">Studio</h2>
        <p class="mt-4 font-serif text-2xl font-bold leading-snug text-brand-teal">
          1250 Baker Ave<br>
          Whitefish, MT 59937
        </p>
        <p class="mt-6">
          <a href="mailto:sally@406strong.com" class="font-semibold text-brand-sky no-underline hover:underline">sally@406strong.com</a>
        </p>
        <p class="mt-6 text-base text-brand-muted">
          Replies are typically within one to two business days. Prefer to reach out directly? Email works too—we read every message.
        </p>
      </div>
    </div>
  </div>
</div>
